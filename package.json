{
  "name": "sante-ci",
  "version": "1.0.0",
  "private": true,
  "description": "SANTÉ-CI — Système de Gestion d'Assurance Maladie (Côte d'Ivoire)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "app:up": "docker compose -f infra/docker/docker-compose.yml --profile app up -d",
    "app:down": "docker compose -f infra/docker/docker-compose.yml --profile app down",
    "app:logs": "docker compose -f infra/docker/docker-compose.yml --profile app logs -f",
    "app:build": "docker compose -f infra/docker/docker-compose.yml --profile app build",
    "docker:ps": "docker compose -f infra/docker/docker-compose.yml --profile app ps",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
