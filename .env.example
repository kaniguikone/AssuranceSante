# =============================================================================
# SANTÉ-CI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER le fichier .env
# =============================================================================

# ── Environnement ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Base de données PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sante_ci
POSTGRES_PASSWORD=change_me_in_production

# Bases de données par service
DB_AUTH=sante_auth
DB_CONTRACT=sante_contract
DB_MEMBER=sante_member
DB_BILLING=sante_billing
DB_PAYMENT=sante_payment
DB_CLAIM=sante_claim
DB_PROVIDER=sante_provider
DB_FRAUD=sante_fraud
DB_ANALYTICS=sante_analytics

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# ── Apache Kafka ───────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── MinIO (Stockage objets) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET_DOCUMENTS=sante-ci-documents
MINIO_BUCKET_IMAGES=sante-ci-images

# ── Keycloak (Auth) ────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=sante-ci
KEYCLOAK_CLIENT_ID=sante-ci-api
KEYCLOAK_CLIENT_SECRET=change_me_in_production
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_with_at_least_64_chars_random_string_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Mobile Money — Orange Money CI ────────────────────────────────────────────
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/ci/v1
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
ORANGE_MONEY_CLIENT_ID=your_client_id
ORANGE_MONEY_CLIENT_SECRET=your_client_secret
ORANGE_MONEY_WEBHOOK_SECRET=your_webhook_secret

# ── Mobile Money — MTN MoMo ───────────────────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_API_USER=your_api_user
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox

# ── Mobile Money — Wave ───────────────────────────────────────────────────────
WAVE_BASE_URL=https://api.wave.com/v1
WAVE_API_KEY=your_wave_api_key
WAVE_WEBHOOK_SECRET=your_webhook_secret

# ── Notifications SMS — Infobip ───────────────────────────────────────────────
INFOBIP_BASE_URL=https://XXXXX.api.infobip.com
INFOBIP_API_KEY=your_infobip_api_key
SMS_SENDER_ID=SANTECI
SMS_COST_FCFA=35

# ── Notifications Email — SendGrid ────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@sante-ci.ci
EMAIL_FROM_NAME=SANTÉ-CI

# ── Push Notifications — Firebase FCM ─────────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# ── WhatsApp Business ─────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── URLs des services (internes) ──────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
CONTRACT_SERVICE_URL=http://localhost:3002
MEMBER_SERVICE_URL=http://localhost:3003
PROVIDER_SERVICE_URL=http://localhost:3004
CLAIM_SERVICE_URL=http://localhost:3005
BILLING_SERVICE_URL=http://localhost:3006
PAYMENT_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
DOCUMENT_SERVICE_URL=http://localhost:3009
ANALYTICS_SERVICE_URL=http://localhost:3010
FRAUD_SERVICE_URL=http://localhost:3011

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:443
NEXT_PUBLIC_APP_NAME=SANTÉ-CI

# ── SNEDAI (Vérification identité nationale — Phase 2) ────────────────────────
SNEDAI_BASE_URL=https://api.snedai.ci
SNEDAI_API_KEY=your_snedai_api_key

# ── Monitoring ────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=your_new_relic_key
SENTRY_DSN=your_sentry_dsn

# ── Chiffrement données sensibles ─────────────────────────────────────────────
ENCRYPTION_KEY=change_me_with_32_chars_hex_string
ENCRYPTION_IV=change_me_16_chars
