{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@sante-ci/types": ["./libs/types/src/index.ts"],
      "@sante-ci/dtos": ["./libs/dtos/src/index.ts"],
      "@sante-ci/utils": ["./libs/utils/src/index.ts"],
      "@sante-ci/constants": ["./libs/constants/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
