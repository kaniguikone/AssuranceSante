# =============================================================================
# SANTÉ-CI — Dockerfile React/Vite (multi-stage, nginx)
# Usage (depuis la racine du monorepo) :
#   docker build -f infra/docker/Dockerfile.web -t sante-ci/web-app:latest .
# =============================================================================

ARG NODE_VERSION=20-alpine
ARG NGINX_VERSION=1.27-alpine

# ── Stage 1 : Build React ────────────────────────────────────────────────────
FROM node:${NODE_VERSION} AS builder

ARG VITE_API_URL=/api
ARG VITE_APP_NAME=SANTÉ-CI
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_APP_NAME=${VITE_APP_NAME}

RUN corepack enable && corepack prepare pnpm@9.1.0 --activate
WORKDIR /app

# Manifestes workspace
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json turbo.json tsconfig.base.json ./

# package.json des libs partagées et du frontend
COPY libs/types/package.json      ./libs/types/
COPY libs/dtos/package.json       ./libs/dtos/
COPY libs/utils/package.json      ./libs/utils/
COPY libs/constants/package.json  ./libs/constants/
COPY apps/web-app/package.json    ./apps/web-app/

# Installation des dépendances
RUN pnpm install --frozen-lockfile --filter @sante-ci/web-app...

# Copier le code source
COPY libs/       ./libs/
COPY apps/web-app/ ./apps/web-app/

# Build production Vite
RUN pnpm --filter @sante-ci/web-app build

# ── Stage 2 : Nginx ──────────────────────────────────────────────────────────
FROM nginx:${NGINX_VERSION} AS runner

# Configuration nginx
COPY infra/docker/nginx/nginx.conf /etc/nginx/conf.d/default.conf

# Copier le build React
COPY --from=builder /app/apps/web-app/dist /usr/share/nginx/html

# Utilisateur non-root
RUN chown -R nginx:nginx /usr/share/nginx/html \
 && chown -R nginx:nginx /var/cache/nginx \
 && chown -R nginx:nginx /var/log/nginx \
 && touch /var/run/nginx.pid \
 && chown nginx:nginx /var/run/nginx.pid

USER nginx

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:80/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
